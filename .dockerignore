# Dependencies
node_modules
.yarn
.pnp.*

# Build outputs
dist
build
.next
.turbo

# Development files
# NOTE: .git is intentionally NOT ignored — the frontend Dockerfile reads the
# short commit SHA from it to tag Sentry releases (see apps/frontend/Dockerfile).
# It only lives in the build stages; the final nginx image doesn't contain it.
# Once Dokploy PR #4007 (DOKPLOY_COMMIT_SHORT build arg) lands upstream, we can
# re-ignore .git and pass VITE_SENTRY_RELEASE=$DOKPLOY_COMMIT_SHORT instead.
.gitignore
*.md
!README.md
CONTRIBUTING.md
DEVELOPMENT_PLAN.md

# IDE
.vscode
.idea
*.swp
*.swo
*~
.opencode

# Tests
coverage
.vitest
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
e2e
playwright-report

# Environment files
.env
.env.*
!.env.example

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Misc
tmp
temp
*.tmp

# Frontend files
netlify.toml
