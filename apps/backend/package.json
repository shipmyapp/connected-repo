{
	"author": "Balkrishna Agarwal <krishna@shipmyapp.in>",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1000.0",
		"@aws-sdk/s3-request-presigner": "^3.1000.0",
		"@better-auth/core": "^1.5.0",
		"@connected-repo/zod-schemas": "*",
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
		"@opentelemetry/instrumentation-http": "^0.212.0",
		"@opentelemetry/instrumentation-pg": "^0.64.0",
		"@opentelemetry/resources": "^2.5.1",
		"@opentelemetry/sdk-node": "^0.212.0",
		"@opentelemetry/sdk-trace-node": "^2.5.1",
		"@orpc/experimental-pino": "^1.13.5",
		"@orpc/openapi": "^1.13.5",
		"@orpc/otel": "^1.13.5",
		"@orpc/server": "^1.13.5",
		"@orpc/zod": "^1.13.5",
		"@sentry/node": "^10.32.1",
		"@sentry/opentelemetry": "^10.32.1",
		"@sentry/profiling-node": "^10.32.1",
		"@suprsend/node-sdk": "^1.13.1",
		"axios": "^1.13.6",
		"better-auth": "^1.5.0",
		"dayjs": "^1.11.19",
		"dotenv": "^17.3.1",
		"node-cron": "^4.2.1",
		"orchid-orm": "^1.63.3",
		"pg": "^8.19.0",
		"pg-tbus": "^1.0.0",
		"pino": "^10.1.0",
		"pino-pretty": "^13.1.3",
		"ua-parser-js": "^2.0.6",
		"ulid": "^3.0.2"
	},
	"description": "Starter Monorepo using Turbo of Nodejs + OrchidORM + oRPC + Reactjs with opentelemetry setup",
	"devDependencies": {
		"@connected-repo/typescript-config": "*",
		"@types/node": "^22.18.12",
		"@types/pg": "^8.18.0",
		"@vitest/coverage-v8": "^4.0.18",
		"@vitest/ui": "^4.0.18",
		"cross-env": "^10.1.0",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.19.2",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"license": "AGPL-3.0-only",
	"main": "src/server.ts",
	"name": "@connected-repo/backend",
	"private": true,
	"repository": "git@github.com:shipmyapp/connected-repo.git",
	"scripts": {
		"build": "tsc && npx tsc-alias",
		"check-types": "tsc --noEmit",
		"clean": "rm -rf node_modules && rm -rf dist",
		"db": "tsx src/db/db_script.ts",
		"dev": "tsx watch --clear-screen=false src/server.ts",
		"dev:inspect": "tsx watch --inspect src/server.ts",
		"format": "biome format . --write",
		"lint": "biome check .",
		"start": "node dist/server.js",
		"test": "cross-env NODE_ENV=test IS_E2E_TEST=false vitest",
		"test:build": "cross-env NODE_ENV=test IS_E2E_TEST=true yarn run build",
		"test:coverage": "cross-env NODE_ENV=test IS_E2E_TEST=false vitest run --coverage",
		"test:db:setup": "cross-env NODE_ENV=test yarn db drop && cross-env NODE_ENV=test yarn db create && cross-env NODE_ENV=test yarn db up && cross-env NODE_ENV=test yarn db seed",
		"test:run": "cross-env NODE_ENV=test IS_E2E_TEST=false vitest run",
		"test:server:start": "cross-env NODE_ENV=test IS_E2E_TEST=true yarn run start",
		"test:ui": "cross-env NODE_ENV=test vitest --ui"
	},
	"version": "1.0.0"
}
