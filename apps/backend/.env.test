# Node Environment
NODE_ENV=test
PORT=3001

# Allowed Origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3001

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=connected_repo_orpc_db_test
DB_SCHEMA=oneq_test

# Google OAuth2 (using dummy values for test)
GOOGLE_WEB_CLIENT_ID=test-google-client-id.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_SECRET=GOCSPX-test-google-client-secret

# Session Secret
SESSION_SECRET=32-characters-or-more-session-secret=key-for-test

# API URLs
WEBAPP_URL=http://localhost:5174
VITE_API_URL=http://localhost:3001

# Internal API Secret
INTERNAL_API_SECRET=32-characters-or-more-internal-api-secret=for-test

# Better Auth Secret
BETTER_AUTH_SECRET=32-characters-or-more-better-auth-secret=for-test

# Cron Job
CRON_JOB_ALLOWED_ORIGIN=
CRON_JOB_TOKEN=32-characters-or-more-cron-job-token=

# OpenTelemetry Configuration
OTEL_SERVICE_NAME=connected-repo-backend

# Sentry Configuration (optional - for error tracking and monitoring)
VITE_SENTRY_DSN=

# Suprsend config
SUPRSEND_API_KEY=supr-key
SUPRSEND_API_SECRET=supr-secret

# Digital Ocean Spaces Bucket (Test dummy)
S3_ENDPOINT=https://blr1.digitaloceanspaces.com
S3_REGION=blr1
S3_ACCESS_KEY_ID=test-key-id
S3_SECRET_ACCESS_KEY=test-secret-key
S3_BUCKET_NAME=test-bucket
S3_PUBLIC_URL=https://test-bucket.blr1.cdn.digitaloceanspaces.com
