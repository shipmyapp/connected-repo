# Node Environment
NODE_ENV=development
PORT=3000

# Allowed Origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=connected_repo_orpc_db

# Google OAuth2 (Phase 2 - using dummy values for Phase 1)
GOOGLE_CLIENT_ID=you-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Session Secret (Phase 2 - using dummy value for Phase 1)
SESSION_SECRET=32-characters-or-more-session-secret=key

# API URLs
WEBAPP_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000

# Internal API Secret (Phase 4 - optional for Phase 1)
INTERNAL_API_SECRET=32-characters-or-more-internal-api-secret=

# Better Auth Secret
BETTER_AUTH_SECRET=32-characters-or-more-better-auth-secret=

# Optional bind host — defaults to 127.0.0.1 in tests, 0.0.0.0 elsewhere.
HOST=

# Pino log level. Defaults to "debug" in dev, "info" otherwise.
LOG_LEVEL=

# DB pool & background-worker tuning
DB_SCHEMA=public
DB_POOL_SIZE=25
PG_TBUS_CONCURRENCY=3

# S3 / object storage (frontend uploads via presigned URLs)
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_URL=

# OpenTelemetry (optional — for OTLP-compatible trace exporters like Tempo/Jaeger)
OTEL_SERVICE_NAME=connected-repo-backend
OTEL_TRACE_EXPORTER_URL=http://localhost:4318/v1/traces

# Sentry — backend-native keys. Leave SENTRY_DSN blank to no-op Sentry entirely.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
# Defaults: 0.1 in prod, 1.0 elsewhere for traces; 0 for profiles.
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_PROFILES_SAMPLE_RATE=

# Novu — notifications. Leave NOVU_SECRET_KEY blank to no-op notifications.
NOVU_SECRET_KEY=
# Optional self-hosted / EU region API URL. Defaults to Novu Cloud when unset.
NOVU_API_URL=

# Super-admin gate — comma-separated emails or phone numbers granted access.
SUPER_ADMIN_EMAILS=
SUPER_ADMIN_PHONE_NUMBERS=