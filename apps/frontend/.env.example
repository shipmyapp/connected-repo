# Node Environment
NODE_ENV=development

# Frontend Configuration
# Leave EMPTY to mimic prod (same-origin): the SPA calls /api/* on its own
# origin and either the Vite dev-server proxy (host-mode `yarn dev`) or the
# nginx sidecar (`docker compose -f docker-compose.dev.yml up`) forwards to
# backend. Set only if you want the client to hit an absolute backend URL.
VITE_API_URL=

# Host-mode dev only — where the Vite proxy forwards /api/* to. Defaults to
# http://localhost:3000 which is where `yarn dev` runs the backend.
VITE_DEV_BACKEND_PROXY_TARGET=

# Test Credentials (only used when NODE_ENV=test)
VITE_TEST_PASSWORD=SecureTestPassword123!@#

# OpenTelemetry Configuration (optional - for trace export)
VITE_OTEL_SERVICE_NAME=connected-repo-backend

# Sentry Configuration (optional - for error tracking and monitoring)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENV=development

VITE_SENTRY_ORG=
VITE_SENTRY_PROJECT=
VITE_SENTRY_AUTH_TOKEN=