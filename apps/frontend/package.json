	"scripts": {
		"build": "tsc -b && npx vite build",
		"build:debug": "tsc -b tsconfig.app.json && vite build --debug",
		"check-types": "tsc --noEmit",
		"clean": "rm -rf node_modules && rm -rf dist",
		"dev": "vite",
		"format": "biome format . --write",
		"lint": "biome check .",
		"preview": "cross-env VITE_USER_APP_URL=http://localhost:4173 bash -c 'if [[ \"$*\" == *\"--no-build\"* ]]; then vite preview; else yarn run build && vite preview; fi' --",
		"test:build": "tsc -b && vite build --mode test",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"type": "module",
	"version": "0.0.0"
